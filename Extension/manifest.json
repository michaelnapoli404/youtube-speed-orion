{
  "manifest_version": 2,
  "name": "YouTube Speed Control",
  "version": "1.0",
  "description": "Scrub left/right to control YouTube playback speed.",

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "images/icon-16.png",
      "32":  "images/icon-32.png",
      "48":  "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },

  "permissions": ["storage"],

  "icons": {
    "16":  "images/icon-16.png",
    "32":  "images/icon-32.png",
    "48":  "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
